<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
  <title>GodMaster Mobile</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
 
    body {
      background: #0a0a0a;
      color: #00ff00;
      font-family: 'Segoe UI', Arial, sans-serif;
      height: 100dvh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
 
    /* ── Üst Bar ── */
    #topbar {
      background: #1a1a1a;
      border-bottom: 1px solid #2a2a2a;
      padding: 10px 14px;
      display: flex;
      align-items: center;
      gap: 10px;
      flex-shrink: 0;
    }
 
    #topbar h1 {
      font-size: 15px;
      font-weight: 700;
      color: #00ff00;
      letter-spacing: 1px;
      flex: 1;
    }
 
    #lang-select {
      background: #2a2a2a;
      color: #aaa;
      border: 1px solid #444;
      border-radius: 6px;
      padding: 4px 8px;
      font-size: 12px;
    }
 
    #clear-btn {
      background: #2a2a2a;
      color: #ff4444;
      border: 1px solid #444;
      border-radius: 6px;
      padding: 4px 10px;
      font-size: 12px;
      cursor: pointer;
    }
    #clear-btn:active { background: #3a1a1a; }
 
    /* ── VU Metre ── */
    #vu-wrap {
      height: 4px;
      background: #111;
      flex-shrink: 0;
    }
    #vu-bar {
      height: 4px;
      width: 0%;
      background: #00ff00;
      transition: width 0.05s;
    }
 
    /* ── Metin Alanı ── */
    #output {
      flex: 1;
      overflow-y: auto;
      padding: 16px;
      font-size: 20px;
      font-weight: 600;
      line-height: 1.6;
      word-break: break-word;
    }
 
    #interim {
      color: #007700;
      font-style: italic;
    }
 
    /* ── Alt Kontrol ── */
    #controls {
      background: #1a1a1a;
      border-top: 1px solid #2a2a2a;
      padding: 14px 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      flex-shrink: 0;
    }
 
    #mic-btn {
      width: 70px;
      height: 70px;
      border-radius: 50%;
      border: 3px solid #00ff00;
      background: #111;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
      flex-shrink: 0;
    }
    #mic-btn.active {
      background: #003300;
      border-color: #00ff00;
      box-shadow: 0 0 20px #00ff0055;
      animation: pulse 1.2s infinite;
    }
    #mic-btn svg {
      width: 32px;
      height: 32px;
      fill: #00ff00;
    }
 
    @keyframes pulse {
      0%, 100% { box-shadow: 0 0 10px #00ff0033; }
      50%       { box-shadow: 0 0 30px #00ff0088; }
    }
 
    #status {
      font-size: 12px;
      color: #555;
      text-align: center;
      line-height: 1.4;
    }
    #status.on { color: #00cc00; }
    #status.err { color: #ff4444; }
 
    /* ── Font Boyutu Slider ── */
    #font-wrap {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 0 16px 10px;
      flex-shrink: 0;
    }
    #font-wrap label { font-size: 11px; color: #555; white-space: nowrap; }
    #font-slider { flex: 1; accent-color: #00ff00; }
 
    /* ── Destek uyarısı ── */
    #no-support {
      display: none;
      text-align: center;
      padding: 40px 20px;
      color: #ff4444;
      font-size: 15px;
    }
  </style>
</head>
<body>
 
<div id="topbar">
  <h1>🎮 GodMaster</h1>
  <select id="lang-select">
    <option value="tr-TR" selected>🇹🇷 Türkçe</option>
    <option value="en-US">🇺🇸 English</option>
    <option value="de-DE">🇩🇪 Deutsch</option>
    <option value="es-ES">🇪🇸 Español</option>
    <option value="fr-FR">🇫🇷 Français</option>
  </select>
  <button id="clear-btn">Temizle</button>
</div>
 
<div id="vu-wrap"><div id="vu-bar"></div></div>
 
<div id="output">
  <span id="final-text"></span><span id="interim"></span>
</div>
 
<div id="font-wrap">
  <label>Yazı:</label>
  <input type="range" id="font-slider" min="14" max="36" value="20" />
</div>
 
<div id="controls">
  <div>
    <div id="mic-btn" onclick="toggleMic()">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 1a4 4 0 0 1 4 4v6a4 4 0 0 1-8 0V5a4 4 0 0 1 4-4zm-1 
                 17.93V21H9v2h6v-2h-2v-2.07A8 8 0 0 0 20 11h-2a6 6 0 0 1-12 
                 0H4a8 8 0 0 0 7 7.93z"/>
      </svg>
    </div>
    <div id="status">Başlamak için dokun</div>
  </div>
</div>
 
<div id="no-support">
  ⚠️ Tarayıcınız ses tanımayı desteklemiyor.<br/>
  Lütfen <b>Chrome</b> veya <b>Safari</b> kullanın.
</div>
 
<script>
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
 
  if (!SpeechRecognition) {
    document.getElementById('no-support').style.display = 'block';
    document.getElementById('controls').style.display = 'none';
  }
 
  let recognition = null;
  let isRunning = false;
  let finalText = '';
  let audioCtx = null, analyser = null, micStream = null, animFrame = null;
 
  const micBtn    = document.getElementById('mic-btn');
  const status    = document.getElementById('status');
  const finalEl   = document.getElementById('final-text');
  const interimEl = document.getElementById('interim');
  const vuBar     = document.getElementById('vu-bar');
  const output    = document.getElementById('output');
  const langSel   = document.getElementById('lang-select');
  const fontSlider= document.getElementById('font-slider');
 
  fontSlider.addEventListener('input', () => {
    output.style.fontSize = fontSlider.value + 'px';
  });
 
  document.getElementById('clear-btn').addEventListener('click', () => {
    finalText = '';
    finalEl.textContent = '';
    interimEl.textContent = '';
  });
 
  function toggleMic() {
    if (isRunning) stopAll();
    else startAll();
  }
 
  function startAll() {
    if (!SpeechRecognition) return;
 
    recognition = new SpeechRecognition();
    recognition.lang = langSel.value;
    recognition.continuous = true;
    recognition.interimResults = true;
    recognition.maxAlternatives = 1;
 
    recognition.onstart = () => {
      isRunning = true;
      micBtn.classList.add('active');
      status.textContent = '🔴 Dinleniyor...';
      status.className = 'on';
    };
 
    recognition.onresult = (e) => {
      let interim = '';
      for (let i = e.resultIndex; i < e.results.length; i++) {
        const t = e.results[i][0].transcript;
        if (e.results[i].isFinal) {
          finalText += t + '\n';
        } else {
          interim = t;
        }
      }
      finalEl.textContent = finalText;
      interimEl.textContent = interim;
      output.scrollTop = output.scrollHeight;
    };
 
    recognition.onerror = (e) => {
      status.textContent = '⚠ ' + e.error;
      status.className = 'err';
      if (e.error !== 'no-speech') stopAll();
    };
 
    recognition.onend = () => {
      // Otomatik yeniden başlat (sürekli dinleme)
      if (isRunning) {
        try { recognition.start(); } catch(e) {}
      }
    };
 
    recognition.start();
    startVU();
  }
 
  function stopAll() {
    isRunning = false;
    micBtn.classList.remove('active');
    status.textContent = 'Başlamak için dokun';
    status.className = '';
    if (recognition) { try { recognition.stop(); } catch(e) {} }
    stopVU();
  }
 
  // ── VU Metre (Web Audio API) ──
  function startVU() {
    if (!navigator.mediaDevices) return;
    navigator.mediaDevices.getUserMedia({ audio: true }).then(stream => {
      micStream = stream;
      audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      analyser = audioCtx.createAnalyser();
      analyser.fftSize = 256;
      const src = audioCtx.createMediaStreamSource(stream);
      src.connect(analyser);
      const buf = new Uint8Array(analyser.frequencyBinCount);
      function draw() {
        animFrame = requestAnimationFrame(draw);
        analyser.getByteFrequencyData(buf);
        const avg = buf.reduce((a, b) => a + b, 0) / buf.length;
        vuBar.style.width = Math.min(avg / 128 * 100, 100) + '%';
      }
      draw();
    }).catch(() => {});
  }
 
  function stopVU() {
    if (animFrame) cancelAnimationFrame(animFrame);
    if (micStream) micStream.getTracks().forEach(t => t.stop());
    if (audioCtx) audioCtx.close();
    vuBar.style.width = '0%';
  }
</script>
</body>
</html>
 
